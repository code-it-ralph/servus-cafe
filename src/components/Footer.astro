---
import siteConfig from '../data/siteConfig.json';
const currentYear = new Date().getFullYear();
---

<footer class="bg-coffee-900 text-coffee-50 py-12 border-t border-coffee-800">
  <div class="max-w-6xl mx-auto px-4 text-center">
    <h2 class="font-serif text-2xl font-bold mb-4">{siteConfig.businessName}</h2>
    <p class="mb-6 opacity-80">{siteConfig.contact.address}</p>
    
    <div class="flex justify-center gap-6 mb-8">
      <a href={`tel:${siteConfig.contact.phone}`} class="hover:text-coffee-500 transition-colors">Call Us</a>
      <a href={siteConfig.contact.messengerLink} target="_blank" class="hover:text-coffee-500 transition-colors">Messenger</a>
    </div>

    <div class="text-sm opacity-60">
      &copy; {currentYear} {siteConfig.businessName}. All rights reserved.<br/>
      <span class="mt-2 inline-block">Website designed by Your Studio</span>
    </div>
  </div>
</footer>
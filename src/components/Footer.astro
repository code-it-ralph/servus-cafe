---
import siteConfig from '../data/siteConfig.json';
const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-900 text-stone-50 py-12 border-t border-stone-800">
  <div class="max-w-6xl mx-auto px-4 text-center">
    <h2 class="font-serif text-2xl font-bold mb-4">
      {siteConfig.businessName}
    </h2>
    <p class="mb-6 opacity-80">{siteConfig.contact.address}</p>

    <div class="mb-10">
      <p
        class="text-xs uppercase tracking-[0.2em] font-bold text-brand-100 mb-6"
      >
        Connect with us
      </p>
      <div class="flex justify-center flex-wrap gap-8">
        <a
          href={`tel:${siteConfig.contact.phone}`}
          class="group flex flex-col items-center gap-2 hover:text-brand-500 transition-all duration-300"
          title="Call Us"
        >
          <div
            class="bg-stone-800 p-3 rounded-full group-hover:bg-brand-500 group-hover:-translate-y-1 transition-all duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </div>
          <span
            class="text-[10px] font-bold uppercase tracking-wider opacity-60 group-hover:opacity-100 transition-opacity"
            >Call</span
          >
        </a>

        {
          siteConfig.contact.facebook && (
            <a
              href={siteConfig.contact.facebook}
              target="_blank"
              class="group flex flex-col items-center gap-2 hover:text-brand-500 transition-all duration-300"
              title="Facebook"
            >
              <div class="bg-stone-800 p-3 rounded-full group-hover:bg-brand-500 group-hover:-translate-y-1 transition-all duration-300">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                </svg>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-wider opacity-60 group-hover:opacity-100 transition-opacity">
                Facebook
              </span>
            </a>
          )
        }

        {
          siteConfig.contact.instagram && (
            <a
              href={siteConfig.contact.instagram}
              target="_blank"
              class="group flex flex-col items-center gap-2 hover:text-brand-500 transition-all duration-300"
              title="Instagram"
            >
              <div class="bg-stone-800 p-3 rounded-full group-hover:bg-brand-500 group-hover:-translate-y-1 transition-all duration-300">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                </svg>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-wider opacity-60 group-hover:opacity-100 transition-opacity">
                Instagram
              </span>
            </a>
          )
        }

        {
          siteConfig.contact.tiktok && (
            <a
              href={siteConfig.contact.tiktok}
              target="_blank"
              class="group flex flex-col items-center gap-2 hover:text-brand-500 transition-all duration-300"
              title="TikTok"
            >
              <div class="bg-stone-800 p-3 rounded-full group-hover:bg-brand-500 group-hover:-translate-y-1 transition-all duration-300">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" />
                </svg>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-wider opacity-60 group-hover:opacity-100 transition-opacity">
                TikTok
              </span>
            </a>
          )
        }
      </div>
    </div>

    <div class="text-sm opacity-60">
      &copy; {currentYear}
      {siteConfig.businessName}. All rights reserved.<br />
      <span class="mt-2 inline-block">Website designed by code-it-ralph</span>
    </div>
  </div>
</footer>

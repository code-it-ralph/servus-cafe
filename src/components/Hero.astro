---
import siteConfig from '../data/siteConfig.json';
import heroBg from '../assets/images/shop.jpg';
---

<section
  class="relative h-[80vh] flex items-center justify-center text-center px-4"
>
  <div class="absolute inset-0 z-0">
    <img
      src={heroBg.src}
      alt="Servus Cafe Nature Vibe"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-stone-900/60"></div>
  </div>

  <div class="relative z-10 max-w-2xl mt-16">
    <h1
      class="font-serif text-5xl md:text-7xl font-bold text-white mb-4 drop-shadow-md"
    >
      {siteConfig.businessName}
    </h1>
    <p class="text-lg md:text-xl text-stone-50 mb-8 font-medium">
      {siteConfig.tagline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#menu"
        class="bg-white text-stone-900 px-8 py-3 rounded-full font-bold hover:bg-stone-50 transition-colors shadow-lg"
      >
        View Menu
      </a>
      <a
        href="#location"
        class="bg-transparent border-2 border-white text-white px-8 py-3 rounded-full font-bold hover:bg-white/10 transition-colors"
      >
        Get Directions
      </a>
    </div>
  </div>
</section>

---
import menuData from '../data/menu.json';
---

<section id="menu" class="py-20 max-w-4xl mx-auto px-4">
  <div class="text-center mb-12">
    <h2 class="font-serif text-4xl font-bold text-coffee-900 mb-4">Our Menu</h2>
    <div class="w-16 h-1 bg-coffee-500 mx-auto"></div>
  </div>

  <div class="space-y-12">
    {menuData.map((category) => (
      <div>
        <h3 class="text-2xl font-bold text-coffee-800 border-b-2 border-coffee-100 pb-2 mb-6">
          {category.category}
        </h3>
        <div class="grid md:grid-cols-2 gap-8">
          {category.items.map((item) => (
            <div class="flex justify-between items-start gap-4">
              <div>
                <h4 class="font-bold text-lg text-coffee-900">{item.name}</h4>
                <p class="text-sm text-coffee-800/70 mt-1">{item.description}</p>
              </div>
              <span class="font-mono font-bold text-coffee-500 whitespace-nowrap">
                ₱{item.price}
              </span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
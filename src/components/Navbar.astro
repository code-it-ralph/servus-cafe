---
import siteConfig from '../data/siteConfig.json';
import logoImg from '../assets/images/logo.png';
---

<header class="fixed w-full bg-stone-50 border-b border-stone-200 z-50">
  <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
    <a
      href={import.meta.env.BASE_URL}
      class="flex items-center gap-3 font-serif font-bold text-xl text-stone-900 tracking-tight"
    >
      <img
        src={logoImg.src}
        alt="Servus Cafe Logo"
        class="w-10 h-10 rounded-full object-cover"
      />
      {siteConfig.businessName}
    </a>
    <nav class="hidden md:flex gap-6 font-semibold text-sm">
      <a href="#about" class="hover:text-brand-500 transition-colors">About</a>
      <a href="#menu" class="hover:text-brand-500 transition-colors">Menu</a>
      <a href="#location" class="hover:text-brand-500 transition-colors"
        >Location</a
      >
    </nav>
    <a
      href={siteConfig.contact.facebook}
      target="_blank"
      class="bg-brand-500 text-white px-4 py-2 text-sm rounded-full hover:bg-brand-600 transition-colors"
    >
      Order Now
    </a>
  </div>
</header>

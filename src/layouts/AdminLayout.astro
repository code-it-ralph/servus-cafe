---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/logo.svg`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Admin Dashboard</title>
  </head>
  <body class="bg-gray-100 text-gray-900 font-sans min-h-screen">
    <nav class="bg-slate-800 text-white p-4 shadow-md">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <h1 class="text-xl font-mono font-bold">DEV_DASHBOARD // {title}</h1>
        <a
          href={import.meta.env.BASE_URL}
          class="text-sm bg-slate-700 hover:bg-slate-600 px-3 py-1 rounded transition-colors"
          >Back to Site</a
        >
      </div>
    </nav>

    <main class="max-w-7xl mx-auto p-6">
      <slot />
    </main>

    <footer class="max-w-7xl mx-auto p-6 text-gray-500 text-sm font-mono">
      &copy; {new Date().getFullYear()} Servus Cafe Internal Tools
    </footer>
  </body>
</html>

<style is:global>
  @reference "../styles/global.css";

  /* Utilitarian styles for admin */
  .admin-card {
    @apply bg-white p-6 rounded-lg border border-stone-200 shadow-sm mb-6;
  }
  .admin-label {
    @apply block text-sm font-semibold text-stone-700 mb-1 uppercase tracking-wider;
  }
  .admin-input {
    @apply w-full p-2 border border-stone-300 rounded focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all mb-4;
  }
  .admin-btn-primary {
    @apply bg-stone-900 text-white px-4 py-2 rounded font-bold hover:bg-stone-800 transition-colors disabled:opacity-50;
  }
  .admin-btn-secondary {
    @apply bg-stone-200 text-stone-800 px-4 py-2 rounded font-bold hover:bg-stone-300 transition-colors;
  }
  .admin-btn-danger {
    @apply bg-red-600 text-white px-4 py-2 rounded font-bold hover:bg-red-700 transition-colors;
  }
</style>

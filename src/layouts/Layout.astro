---
import siteConfig from '../data/siteConfig.json';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const siteUrl = Astro.site ? Astro.site.origin : '';
const fullFaviconUrl = `${siteUrl}${baseUrl}favicon.ico?v=3`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={siteConfig.tagline} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href={fullFaviconUrl} />
    <link rel="shortcut icon" type="image/x-icon" href={fullFaviconUrl} />
    <link
      rel="icon"
      type="image/png"
      href={`${import.meta.env.BASE_URL}logo.png?v=3`}
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}logo.svg?v=3`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Merriweather:ital,wght@0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <title>
      {
        title === siteConfig.businessName
          ? title
          : `${title} | ${siteConfig.businessName}`
      }
    </title>
  </head>
  <body class="bg-stone-50 text-stone-900 font-sans antialiased">
    <slot />
  </body>
</html>
